# Sao chép file này thành .env (local) hoặc khai báo trong Vercel > Settings > Environment Variables

# Connection string từ MongoDB Atlas (Connect > Drivers)
# Nhớ thay <password> và đặt tên database sau dấu "/"
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# (Tùy chọn) Tên database, mặc định: house_split
MONGODB_DB="house_split"
